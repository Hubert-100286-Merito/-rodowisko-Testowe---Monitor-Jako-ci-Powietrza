# --- Ustawienia ogólne ---
# Nazwa projektu dla dockera
PROJECT_NAME=air-quality-monitor

# --- Backend (FastAPI) ---
# Czas w godzinach ważności danych w DB (zgodnie z wymaganiem RF-05, RF-06)
CACHE_TTL_HOURS=1
# Adres bazy danych SQLite
DATABASE_URL=sqlite:///./data/air_quality.db
# Adres hosta dla Redisa (wewnątrz sieci Dockerowej nazwa usługi to "redis")
REDIS_HOST=redis
REDIS_PORT=6379

# --- Frontend (React + Vite) ---
# Adres, pod którym backend będzie dostępny dla frontendu
# (Vite wymaga prefixu VITE_ dla zmiennych dostępnych w kodzie)
VITE_API_URL=http://localhost:8000

# --- Klucze API (opcjonalnie, jeśli używacie płatnych źródeł) ---
# OPENAQ_API_KEY=twoj_klucz_tutaj